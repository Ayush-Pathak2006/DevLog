generator client {
 provider = "prisma-client-js"
}

datasource db {
 provider = "sqlite"
}

enum ProjectStatus {
 IDEA
 BUILDING
 SHIPPED
 PAUSED
}

model Project {
 id          String   @id @default(cuid())
 name        String
 description String
 status      ProjectStatus

 entries     Entry[]
 resources   Resource[]

 createdAt   DateTime @default(now())
}

model Entry {
 id        String   @id @default(cuid())
 title     String
 content   String

 projectId String
 project   Project @relation(fields: [projectId], references: [id])

 createdAt DateTime @default(now())
}

model Resource {
 id        String   @id @default(cuid())
 title     String
 url       String
 category  String

 projectId String
 project   Project  @relation(fields: [projectId], references: [id])

 createdAt DateTime @default(now())
}